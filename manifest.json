{
  "manifest_version": 3,
  "name": "AI捷径 (AI Shortcuts)",
  "short_name": "AI捷径",
  "version": "1.3.60",
  "description": "多AI站点脚本合集",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "scripting",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://business.gemini.google/*",
    "https://cdn.openai.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://chat.z.ai/*",
    "https://chatgpt.com/*",
    "https://ernie.baidu.com/*",
    "https://gemini.google.com/app*",
    "https://grok.com/*",
    "https://kimi.com/*",
    "https://www.genspark.ai/*",
    "https://www.kimi.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "bypass_headers",
        "enabled": true,
        "path": "rules/bypass-headers.json"
      }
    ]
  },
  "background": {
    "service_worker": "background/sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://business.gemini.google/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://chat.z.ai/*",
        "https://chatgpt.com/*",
        "https://ernie.baidu.com/*",
        "https://gemini.google.com/app*",
        "https://grok.com/*",
        "https://kimi.com/*",
        "https://www.genspark.ai/*",
        "https://www.kimi.com/*"
      ],
      "js": [
        "content/bootstrap.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "AI捷径",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [],
  "minimum_chrome_version": "96"
}
