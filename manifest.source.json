{
  "manifest_version": 3,
  "name": "AI捷径 (AI Shortcuts)",
  "short_name": "AI捷径",
  "version": "4.0.0",
  "description": "多AI站点脚本合集",
  "permissions": [
    "scripting",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chat.qwen.ai/*",
    "https://chat.z.ai/*",
    "https://chatgpt.com/*",
    "https://developers.openai.com/*",
    "https://ernie.baidu.com/*",
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://kimi.com/*",
    "https://meta.ai/*",
    "https://www.genspark.ai/*",
    "https://www.google.com/*",
    "https://www.kimi.com/*",
    "https://www.meta.ai/*"
  ],
  "background": {
    "service_worker": "background/sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://chat.z.ai/*",
        "https://chatgpt.com/*",
        "https://ernie.baidu.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://kimi.com/*",
        "https://meta.ai/*",
        "https://www.genspark.ai/*",
        "https://www.google.com/*",
        "https://www.kimi.com/*",
        "https://www.meta.ai/*"
      ],
      "js": [
        "shared/i18n.js",
        "content/bootstrap.js",
        "content/dom-i18n.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "AI捷径",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [],
  "minimum_chrome_version": "96"
}
